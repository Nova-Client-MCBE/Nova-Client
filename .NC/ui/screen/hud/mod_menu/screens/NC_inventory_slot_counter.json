{
  "namespace": "Nova_Client_inventory_slot_counter_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "inventory_slot_counter_out",
    "anims": [
      "@Nova_Client_animations.inventory_slot_counter_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "inventory_slot_counter_icon_toggle",
          "$toggle_tags": "$inventory_slot_counter_icon",
          "$NC_dialog_toggle_text": "Icon",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "inv_slot_opacity",
          "$NC_opacity_default_value": "$inventory_slot_opacity",
          "$NC_slider_section_offset": [ 0, 25 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.inventory_slot_counter_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
