{
  "namespace": "Nova_Client_clock_and_compass_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "clock_and_compass_out",
    "anims": [
      "@Nova_Client_animations.clock_and_compass_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "compass_toggle",
          "$toggle_tags": "$compass",
          "$NC_dialog_toggle_text": "Compass",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "2@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "clock_toggle",
          "$toggle_tags": "$clock",
          "$NC_dialog_toggle_text": "Clock",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "3@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "recovery_toggle",
          "$toggle_tags": "$recovery_compass",
          "$NC_dialog_toggle_text": "Recovery Compass",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 50 ]
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "clock_and_compass_opacity",
          "$NC_opacity_default_value": "$clock_and_compass_opacity",
          "$NC_slider_section_offset": [ 0, 75 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.clock_and_compass_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
