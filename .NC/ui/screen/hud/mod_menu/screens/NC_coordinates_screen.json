{
  "namespace": "Nova_Client_coordinates_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "coordinates_out",
    "anims": [
      "@Nova_Client_animations.coordinates_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "default_coords_toggle",
          "$toggle_tags": "$default_coordinates",
          "$NC_dialog_toggle_text": "Coordinates",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "3@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "chunk_coords_toggle",
          "$toggle_tags": "$chunk_coordinates",
          "$NC_dialog_toggle_text": "Chunk",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "coords_opacity",
          "$NC_opacity_default_value": "$coordinates_opacity",
          "$NC_slider_section_offset": [ 0, 50 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.coordinates_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
