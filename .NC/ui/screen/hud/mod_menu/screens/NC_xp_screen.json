{
  "namespace": "Nova_Client_xp_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "xp_calculator_screen_out",
    "anims": [
      "@Nova_Client_animations.xp_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "xp_point_calculator_icon_toggle",
          "$toggle_tags": "$exp_panel_icon",
          "$NC_dialog_toggle_text": "Icon",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "2@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "xp_panel_point_toggle",
          "$toggle_tags": "$exp_points",
          "$NC_dialog_toggle_text": "EXP Points",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "3@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "xp_panel_level_toggle",
          "$toggle_tags": "$exp_level",
          "$NC_dialog_toggle_text": "EXP Levels",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 50 ]
        }
      },
      {
        "4@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "xp_panel_buffer",
          "$toggle_tags": "$exp_panel_buffer",
          "$NC_dialog_toggle_text": "Buffer",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 75 ]
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "exp_calculator_opacity",
          "$NC_opacity_default_value": "$exp_panel_opacity",
          "$NC_slider_section_offset": [ 0, 100 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.xp_calculator_screen_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
