{
  "namespace": "Nova_Client_moon_phase_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "moon_phase_out",
    "anims": [
      "@Nova_Client_animations.moon_phase_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "moon_phase_text_toggle",
          "$toggle_tags": "$moon_phase_text",
          "$NC_dialog_toggle_text": "Text",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "2@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "moon_phase_icon_toggle",
          "$toggle_tags": "$moon_phase_icon",
          "$NC_dialog_toggle_text": "Icon",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "moon_phase_opacity",
          "$NC_opacity_default_value": "$moon_phase_opacity",
          "$NC_slider_section_offset": [ 0, 50 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.moon_phase_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
