{
  "namespace": "Nova_Client_main_hand_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "main_hand_out",
    "anims": [
      "@Nova_Client_animations.main_hand_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "2@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "mainhand_item_toggle",
          "$toggle_tags": "$mainhand_item",
          "$NC_dialog_toggle_text": "Item",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "3@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "mainhand_stack_toggle",
          "$toggle_tags": "$mainhand_stack",
          "$NC_dialog_toggle_text": "Amount",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "4@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "mainhand_durability_toggle",
          "$toggle_tags": "$mainhand_durability",
          "$NC_dialog_toggle_text": "Durability",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 50 ]
        }
      },
      {
        "slot_opacity@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "mainhand_slot_opacity",
          "$NC_opacity_default_value": "$mainhand_slot_opacity",
          "$NC_slider_section_offset": [ 0, 75 ]
        }
      },
      {
        "bg_opacity@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "mainhand_percent_opacity",
          "$NC_opacity_default_value": "$mainhand_durability_opacity",
          "$NC_slider_section_offset": [ 0, 100 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.main_hand_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
