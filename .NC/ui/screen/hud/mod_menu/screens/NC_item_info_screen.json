{
  "namespace": "Nova_Client_item_info_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "item_info_out",
    "anims": [
      "@Nova_Client_animations.item_info_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "item_info_item_name",
          "$toggle_tags": "$item_info_item_name",
          "$NC_dialog_toggle_text": "Item Name",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "2@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "item_aux_id",
          "$toggle_tags": "$item_aux_id",
          "$NC_dialog_toggle_text": "Aux ID",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "3@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "item_id_toggle",
          "$toggle_tags": "$item_id",
          "$NC_dialog_toggle_text": "Item ID",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 50 ]
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "item_info_opacity",
          "$NC_opacity_default_value": "$item_info_opacity",
          "$NC_slider_section_offset": [ 0, 75 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.item_info_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
