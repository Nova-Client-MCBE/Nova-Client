{
  "namespace": "Nova_Client_item_counter_screen",
  "content@Nova_Client_common.screen_template": {
    "$NC_sreen_button_name": "item_counter_out",
    "anims": [
      "@Nova_Client_animations.item_counter_screen",
      "@Nova_Client_animations.screen_page_out"
    ],
    "controls": [
      { "background@Nova_Client_common.screen_bg": {} },
      {
        "1@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "item_counter_arrow",
          "$toggle_tags": "$arrow_counter",
          "$NC_dialog_toggle_text": "Arrows",
          "$NC_dialog_toggle_anchor": "top_middle"
        }
      },
      {
        "2@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "item_counter_potion",
          "$toggle_tags": "$potion_counter",
          "$NC_dialog_toggle_text": "Potions",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 25 ]
        }
      },
      {
        "3@Nova_Client_dialog_toggle_template.content": {
          "$toggle_view_binding_name": "item_counter_totem",
          "$toggle_tags": "$totem_counter",
          "$NC_dialog_toggle_text": "Totems",
          "$NC_dialog_toggle_anchor": "top_middle",
          "offset": [ 0, 50 ]
        }
      },
      {
        "opacity_slider@Nova_Client_common.opacity_slider_section": {
          "$NC_opacity_slider_name": "item_counter_opacity",
          "$NC_opacity_default_value": "$item_counter_opacity",
          "$NC_slider_section_offset": [ 0, 75 ]
        }
      },
      {
        "close_button@Nova_Client_dialog_toggle_template.close_button": {
          "$pressed_button_name": "button.item_counter_out",
          "$button_text": "Close"
        }
      }
    ]
  }
}
