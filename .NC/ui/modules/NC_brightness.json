{
  "namespace": "Nova_Client_brightness",
  "content@Nova_Client_brightness.template": {
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "brightness_toggle",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ]
  },
  "template": {
    "type": "custom",
    "renderer": "gradient_renderer",
    "color1": "$color1",
    "color2": "$color2",
    "layer": -1,
    "$color1|default": [
      1,
      1,
      1,
      1
    ],
    "$color2|default": [
      1,
      1,
      1,
      1
    ]
  }
}